{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "javalens-manager",
  "version": "0.1.0",
  "identifier": "com.hw1964.javalens-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "javalens-manager",
        "width": 1280,
        "height": 880,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
